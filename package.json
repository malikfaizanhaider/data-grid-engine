    "./cdn": "./dist/cdn/index.umd.min.js",
    "./cdn/dev": "./dist/cdn/index.umd.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx --watch core/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@tanstack/table-core": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/table-core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^22.15.30",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
