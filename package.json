{
  "name": "@engine/data-grid",
  "version": "8.21.3",
  "description": "Headless, framework-agnostic data grid engine for TanStack Table",
  "homepage": "https://tanstack.com/table",
  "bugs": {
    "url": "https://github.com/TanStack/table/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanStack/table.git",
    "directory": "packages/data-grid-engine"
  },
  "license": "MIT",
  "author": "TanStack",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "core": [
        "./dist/grid/index.d.ts"
      ],
      "core/base": [
        "./dist/grid/base/index.d.ts"
      ],
      "core/base/core": [
        "./dist/grid/base/core.d.ts"
      ],
      "core/base/engine": [
