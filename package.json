      ],
      "core/base/events": [
        "./dist/grid/base/events.d.ts"
      ],
      "core/base/faceting": [
        "./dist/grid/base/faceting.d.ts"
      ],
      "core/base/features": [
        "./dist/grid/base/features.d.ts"
      ],
      "core/base/mutations": [
        "./dist/grid/base/mutations.d.ts"
      ],
      "core/base/persistence": [
