      },
      "require": {
        "types": "./dist/grid/base/render-utils.d.ts",
        "default": "./dist/grid/base/render-utils.cjs"
      }
    },
    "./core/base/rendering": {
      "import": {
        "types": "./dist/grid/base/rendering.d.ts",
        "default": "./dist/grid/base/rendering.js"
      },
      "require": {
        "types": "./dist/grid/base/rendering.d.ts",
        "default": "./dist/grid/base/rendering.cjs"
      }
    },
    "./core/base/server": {
      "import": {
        "types": "./dist/grid/base/server.d.ts",
        "default": "./dist/grid/base/server.js"
      },
      "require": {
        "types": "./dist/grid/base/server.d.ts",
